# Copy to .env and fill in values. Never commit .env.

# Core
NODE_ENV=development
PORT=3000

# Postgres / Nile / Neon-compatible database URL
DATABASE_URL=

# Legacy JWT auth used by current /api/auth routes during migration
JWT_SECRET=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google Sign-In / Better Auth Google provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin dashboard code (required for admin actions)
ADMIN_PIN=1234
VITE_ADMIN_EMAILS=

# Duffel (flights)
DUFFEL_API_KEY=

# Events (optional)
EVENTBRITE_TOKEN=
TICKETMASTER_API_KEY=

# CORS: comma-separated origins (recommended in production), e.g.
# ALLOWED_ORIGINS=https://your-site.netlify.app,https://www.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Stripe checkout requires a secret key, not a restricted key.
STRIPE_SECRET_KEY=

# Visa / GitHub storage (Netlify function)
VISA_ADMIN_TOKEN=
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Travel Buddy (Netlify)
TRAVELBUDDY_RAPIDAPI_SECRET=

# Optional: Amadeus (debug scripts only)
# AMADEUS_API_KEY=
# AMADEUS_API_SECRET=
