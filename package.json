{
  "name": "bookingcart",
  "version": "1.0.0",
  "description": "Flight booking application with Amadeus API integration",
  "main": "server.js",
  "scripts": {
    "start": "SERVE_STATIC=1 node server.js",
    "dev": "concurrently -n api,vite -c blue,green \"API_ONLY=1 PORT=3001 node server.js\" \"vite\"",
    "dev:server": "API_ONLY=1 nodemon server.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "flight",
    "booking",
    "amadeus",
    "travel"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@duffel/components": "^3.16.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.7",
    "pg": "^8.21.0",
    "puppeteer": "^24.43.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.1",
    "resend": "^6.12.3",
    "stripe": "^17.7.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vite": "^8.0.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
